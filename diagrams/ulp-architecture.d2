direction: down

title: ULP — Universal Language Project {
  near: top-center
  style: {
    font-size: 28
    bold: true
    font-color: "#e0e0e0"
  }
}

# ── Foundational Layer ──────────────────────────────────────────

foundations: Foundations {
  style: {
    fill: "#1a1a2e"
    stroke: "#4a90d9"
    border-radius: 12
    font-color: "#e0e0e0"
  }

  binary: Binary Alphabet {
    shape: hexagon
    style: {
      fill: "#16213e"
      stroke: "#e94560"
      font-color: "#ffffff"
      bold: true
    }
  }

  zero: "0 — Cut / Distinction\n(Individuator)" {
    style: {
      fill: "#0f3460"
      stroke: "#e94560"
      font-color: "#ffffff"
    }
  }

  one: "1 — Closure / Presence\n(Unbounded existence)" {
    style: {
      fill: "#0f3460"
      stroke: "#53d769"
      font-color: "#ffffff"
    }
  }

  binary -> zero: base symbol
  binary -> one: base symbol
}

# ── Encoding Layer ──────────────────────────────────────────────

encoding: Encoding System {
  style: {
    fill: "#1a1a2e"
    stroke: "#f39c12"
    border-radius: 12
    font-color: "#e0e0e0"
  }

  rle: Run-Length Encoding {
    shape: hexagon
    style: {
      fill: "#16213e"
      stroke: "#f39c12"
      font-color: "#ffffff"
      bold: true
    }
  }

  type_from_length: "Type from run-length alone" {
    style: {
      fill: "#2c2c54"
      stroke: "#f39c12"
      font-color: "#e0e0e0"
    }
  }

  self_delimit: "Self-delimiting parsing" {
    style: {
      fill: "#2c2c54"
      stroke: "#f39c12"
      font-color: "#e0e0e0"
    }
  }

  compositionality: "Compositional\n(meaning from structure)" {
    style: {
      fill: "#2c2c54"
      stroke: "#f39c12"
      font-color: "#e0e0e0"
    }
  }

  rle -> type_from_length
  rle -> self_delimit
  rle -> compositionality
}

# ── Structural Layer ────────────────────────────────────────────

structure: Structural Grammar {
  style: {
    fill: "#1a1a2e"
    stroke: "#9b59b6"
    border-radius: 12
    font-color: "#e0e0e0"
  }

  trigram: "Trigram X.(ko)Z.\n(Left-Individuation Rule)" {
    shape: hexagon
    style: {
      fill: "#16213e"
      stroke: "#9b59b6"
      font-color: "#ffffff"
      bold: true
    }
  }

  nesting: "Nesting = only operator\n(no external relational symbols)" {
    style: {
      fill: "#2c2c54"
      stroke: "#9b59b6"
      font-color: "#e0e0e0"
    }
  }

  no_space: "No-space = containment\nSpace = transformation" {
    style: {
      fill: "#2c2c54"
      stroke: "#9b59b6"
      font-color: "#e0e0e0"
    }
  }

  trigram -> nesting
  trigram -> no_space
}

# ── Dimensional Ladder ──────────────────────────────────────────

ladder: 13-Tier Dimensional Ladder {
  style: {
    fill: "#1a1a2e"
    stroke: "#1abc9c"
    border-radius: 12
    font-color: "#e0e0e0"
  }

  void: "Void" {
    style: {fill: "#0a0a1a"; stroke: "#1abc9c"; font-color: "#888888"}
  }
  point: "Point" {
    style: {fill: "#0f1525"; stroke: "#1abc9c"; font-color: "#aaaaaa"}
  }
  line: "Line" {
    style: {fill: "#142030"; stroke: "#1abc9c"; font-color: "#cccccc"}
  }
  dots: "..." {
    style: {fill: "#1a2a3e"; stroke: "#1abc9c"; font-color: "#888888"}
  }
  consciousness: "Consciousness" {
    style: {fill: "#1f354c"; stroke: "#e94560"; font-color: "#ffffff"; bold: true}
  }
  universal: "Universal\nConsciousness" {
    style: {fill: "#254060"; stroke: "#e94560"; font-color: "#ffffff"; bold: true}
  }

  void -> point -> line -> dots -> consciousness -> universal: geometric closure
}

